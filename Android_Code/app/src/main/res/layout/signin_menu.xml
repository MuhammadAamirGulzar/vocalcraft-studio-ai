<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="@drawable/yellow_background"
    android:layout_height="match_parent">

    <!-- Icon -->
    <ImageView
        android:id="@+id/iconImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.12"
        app:layout_constraintDimensionRatio="1:1"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/megaphone" />

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VocalCraft"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="#FF8C00"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/iconImage"
        app:layout_constraintTop_toTopOf="@id/iconImage"
        app:layout_constraintBottom_toBottomOf="@id/iconImage" />

    <!-- Feature Text -->
    <TextView
        android:id="@+id/featureText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="AI-DRIVEN\nPAMPHLET CREATION\nTHROUGH VOICE\nCOMMANDS"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1f1d4c"
        android:lineSpacingMultiplier="0.9"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconImage"/>

    <!-- Description Text -->
    <TextView
        android:id="@+id/descriptionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Create professional pamphlets effortlessly using voice commands. Our AI technology transforms your spoken words into beautifully designed materials."
        android:textSize="16sp"
        android:textColor="#99000000"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/featureText"/>

    <!-- Microphone Circle -->
    <androidx.cardview.widget.CardView
        android:id="@+id/microphoneContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="10dp"
        android:elevation="24dp"
        android:outlineAmbientShadowColor="#5956fb"
        android:outlineSpotShadowColor="#5956fb"
        android:stateListAnimator="@null"
        android:translationZ="24dp"
        app:cardBackgroundColor="#FF8C00"
        app:cardCornerRadius="1000dp"
        app:cardElevation="24dp"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.22">

        <ImageView
            android:id="@+id/microphoneIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:padding="16dp"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="@android:color/white" />

    </androidx.cardview.widget.CardView>

    <!-- Button Container -->
    <androidx.cardview.widget.CardView
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.35"
        app:cardCornerRadius="30dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#efeefe"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp">

            <!-- Google Sign In -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/googleSignInButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintHeight_percent="0.27"
                android:text="Continue with Google"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#FF8C00"
                android:textColor="@android:color/white"
                app:cornerRadius="15dp"
                app:elevation="8dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp"
                app:icon="@drawable/ic_google"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@android:color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Sign Up -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/signUpButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintHeight_percent="0.27"
                android:text="Sign Up with Email"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#FF8C00"
                android:textColor="#FFFFFF"
                app:cornerRadius="15dp"
                app:elevation="8dp"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp"
                app:icon="@android:drawable/ic_dialog_email"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/googleSignInButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Login -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/signInButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:layout_constraintHeight_percent="0.27"
                android:text="Login To Existing Account"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#ffffff"
                android:textColor="#FF8C00"
                app:cornerRadius="15dp"
                app:elevation="8dp"
                android:stateListAnimator="@null"
                app:icon="@drawable/ic_person"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FF8C00"
                app:layout_constraintTop_toBottomOf="@id/signUpButton"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>