<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/yellow_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- RecyclerView: Each item contains an image + caption -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/imagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

    <!-- Button to pick multiple images -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/pickImagesButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="#f4640b"
        android:stateListAnimator="@null"
        android:text="Pick Images"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="15dp"
        app:elevation="8dp"
        app:icon="@drawable/ic_gallery"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@android:color/white" />

    <!-- Upload button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/uploadButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="#f4640b"
        android:stateListAnimator="@null"
        android:text="Upload to Dropbox"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="15dp"
        app:elevation="8dp"
        app:icon="@drawable/ic_upload"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@android:color/white" />

    <!-- Exit / Continue -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/exitButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:backgroundTint="#f54242"
        android:stateListAnimator="@null"
        android:text="Continue"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="15dp"
        app:elevation="8dp"
        app:icon="@drawable/ic_exit"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconTint="@android:color/white" />

</LinearLayout>
