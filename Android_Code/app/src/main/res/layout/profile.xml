<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ProfileActivity"
    android:background="@drawable/yellow_background">

    <!-- Icon -->
    <ImageView
        android:id="@+id/iconImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintWidth_percent="0.12"
        app:layout_constraintDimensionRatio="1:1"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/megaphone" />

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Profile Setup"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="#FF8C00"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/iconImage"
        app:layout_constraintTop_toTopOf="@id/iconImage"
        app:layout_constraintBottom_toBottomOf="@id/iconImage" />

    <!-- Company Name Input -->
    <androidx.cardview.widget.CardView
        android:id="@+id/companynamecard"
        android:layout_width="333dp"
        android:layout_height="44dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#ffffff"
        app:cardCornerRadius="15dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/iconImage">

        <EditText
            android:id="@+id/companynametextedit"
            android:layout_width="384dp"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_edittext_noborder"
            android:hint="Company Name"
            android:padding="12dp"
            android:textColorHint="#99000000"
            android:textSize="16sp" />

    </androidx.cardview.widget.CardView>

    <!-- Primary Theme Picker -->

    <TextView
        android:id="@+id/primaryThemeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Primary Theme:"
        android:textColor="#5956fb"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/companynamecard" />

    <!-- Secondary Theme Picker -->

    <androidx.cardview.widget.CardView
        android:id="@+id/primaryThemePicker"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#5956fb"
        app:cardCornerRadius="24dp"
        android:background="@drawable/circular_button"
        app:cardPreventCornerOverlap="true"
        app:cardUseCompatPadding="true"
        app:layout_constraintStart_toEndOf="@id/primaryThemeLabel"
        app:layout_constraintTop_toBottomOf="@id/companynamecard" />

    <TextView
        android:id="@+id/secondaryThemeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:text="Secondary Theme:"
        android:textColor="#5956fb"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/primaryThemePicker" />

    <!-- Save Button -->


    <androidx.cardview.widget.CardView
        android:id="@+id/secondaryThemePicker"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#FFA726"
        app:cardCornerRadius="24dp"
        app:cardPreventCornerOverlap="true"
        app:cardUseCompatPadding="true"
        app:layout_constraintStart_toEndOf="@id/secondaryThemeLabel"
        app:layout_constraintTop_toBottomOf="@id/primaryThemePicker" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Save"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="#FF8C00"
        app:cornerRadius="15dp"
        app:elevation="8dp"
        android:stateListAnimator="@null"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/secondaryThemePicker" />

</androidx.constraintlayout.widget.ConstraintLayout>
